# Vertex AI Configuration
# Google Cloud Project ID (从 Google Cloud Console 获取)
VERTEX_AI_PROJECT_ID=

# Vertex AI Location (默认 us-central1)
VERTEX_AI_LOCATION=us-central1

# Vertex AI Image Model (imagen-3.0-generate-001 或 imagen-3.0-fast-generate-001)
VERTEX_AI_IMAGE_MODEL=imagegeneration@006

# 是否启用真实 API 调用 (true/false)
ENABLE_VERTEX_AI=true
