# ============================================
# 特步AI生图助手 - 环境变量配置
# ============================================

# Google API Key (Required for Gemini multimodal model)
# Get your key from: https://aistudio.google.com/
# 使用 GOOGLE_CLOUD_API_KEY（用于 @google/genai SDK）
GOOGLE_CLOUD_API_KEY=your_google_api_key_here

# 测试账号配置（可选，不配置则使用默认值）
# 默认：用户ID=demo，密码=demo123
DEMO_USER_ID=demo
DEMO_PASSWORD=demo123

# ============================================
# 其他配置（一般不需要修改）
# ============================================

# 开发环境
NODE_ENV=development
