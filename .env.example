# ============================================
# 特步AI生图助手 - 环境变量配置
# ============================================

# EasyRouter API 配置（推荐方式）
# 从 https://easyrouter.io 控制台获取
EASYROUTER_API_KEY=sk-your-api-key-here
EASYROUTER_BASE_URL=https://easyrouter.io

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_TOKEN=admin-token-xtep-2024

# ============================================
# 说明
# ============================================
# 1. 用户API Key也可以通过管理后台单独配置
# 2. 未配置API Key的用户将使用 EASYROUTER_API_KEY 作为默认Key
# 3. 模型默认使用 gemini-3.1-flash-image-preview
